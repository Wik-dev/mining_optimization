# RAG module defaults — copy to .env and fill in OPENAI_API_KEY.
# These are loaded by task scripts with override=False, so actual environment
# variables always take precedence over .env values.

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# OpenAI API key (required for embed_chunks, knowledge_query)
OPENAI_API_KEY=

# Embedding
EMBEDDING_MODEL=text-embedding-3-small

# Retrieval
TOP_K=5

# Generation (knowledge_query only)
LLM_MODEL=gpt-4.1-mini
